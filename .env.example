# ================================================================
# SOC Lab — Exemple de configuration (valeurs fictives)
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs
# cp .env.example .env
# ================================================================

# --- Wazuh Indexer (OpenSearch) ---
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WAZUH_INDEXER_PORT=9200

# --- Wazuh API (Manager) ---
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Wazuh Dashboard ---
WAZUH_DASHBOARD_USERNAME=kibanaserver
WAZUH_DASHBOARD_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Cassandra ---
CASSANDRA_CLUSTER_NAME=thehive
CASSANDRA_DC=datacenter1

# --- TheHive ---
THEHIVE_SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_STRING
