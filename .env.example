# ===== WAZUH =====
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=SecurePassword123!
WAZUH_ADMIN_USER=admin
WAZUH_ADMIN_PASSWORD=AdminPass123!

# ===== GRAFANA =====
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=GrafanaPass123!
GF_INSTALL_PLUGINS=grafana-piechart-panel

# ===== THEHIVE =====
THEHIVE_API_KEY=changeme-api-key-32-chars-long!
CASSANDRA_CLUSTER_NAME=thehive
CASSANDRA_DC_NAME=dc1

# ===== SURICATA =====
SURICATA_YAML_CONFIG=/etc/suricata/suricata.yaml

# ===== PORTS =====
WAZUH_MANAGER_PORT_UDP=1514
WAZUH_MANAGER_PORT_TCP=1515
WAZUH_API_PORT=55000
WAZUH_DASHBOARD_PORT=443
GRAFANA_PORT=3000
THEHIVE_PORT=9000

# ===== RÉSEAU =====
DOCKER_NETWORK_BACKEND=soc-backend
DOCKER_NETWORK_FRONTEND=soc-frontend

# ===== VOLUMES =====
WAZUH_DATA_VOLUME=wazuh-data
GRAFANA_DATA_VOLUME=grafana-data
THEHIVE_DATA_VOLUME=thehive-data
CASSANDRA_DATA_VOLUME=cassandra-data
